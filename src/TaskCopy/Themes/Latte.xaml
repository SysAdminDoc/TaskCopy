<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Catppuccin Latte palette (light). Keys keep the Mocha.* prefix so
         every existing XAML reference resolves without churn — the brushes
         are just darker/lighter to match the light variant. -->
    <Color x:Key="Mocha.Base">#FFEFF1F5</Color>
    <Color x:Key="Mocha.Mantle">#FFE6E9EF</Color>
    <Color x:Key="Mocha.Crust">#FFDCE0E8</Color>
    <Color x:Key="Mocha.Text">#FF4C4F69</Color>
    <Color x:Key="Mocha.Subtext1">#FF5C5F77</Color>
    <Color x:Key="Mocha.Subtext0">#FF6C6F85</Color>
    <Color x:Key="Mocha.Overlay2">#FF7C7F93</Color>
    <Color x:Key="Mocha.Overlay1">#FF8C8FA1</Color>
    <Color x:Key="Mocha.Overlay0">#FF9CA0B0</Color>
    <Color x:Key="Mocha.Surface2">#FFACB0BE</Color>
    <Color x:Key="Mocha.Surface1">#FFBCC0CC</Color>
    <Color x:Key="Mocha.Surface0">#FFCCD0DA</Color>
    <Color x:Key="Mocha.Mauve">#FF8839EF</Color>
    <Color x:Key="Mocha.Blue">#FF1E66F5</Color>
    <Color x:Key="Mocha.Lavender">#FF7287FD</Color>
    <Color x:Key="Mocha.Red">#FFD20F39</Color>
    <Color x:Key="Mocha.Green">#FF40A02B</Color>
    <Color x:Key="Mocha.Yellow">#FFDF8E1D</Color>

    <SolidColorBrush x:Key="Mocha.Base.Brush" Color="{StaticResource Mocha.Base}" />
    <SolidColorBrush x:Key="Mocha.Mantle.Brush" Color="{StaticResource Mocha.Mantle}" />
    <SolidColorBrush x:Key="Mocha.Crust.Brush" Color="{StaticResource Mocha.Crust}" />
    <SolidColorBrush x:Key="Mocha.Text.Brush" Color="{StaticResource Mocha.Text}" />
    <SolidColorBrush x:Key="Mocha.Subtext1.Brush" Color="{StaticResource Mocha.Subtext1}" />
    <SolidColorBrush x:Key="Mocha.Subtext0.Brush" Color="{StaticResource Mocha.Subtext0}" />
    <SolidColorBrush x:Key="Mocha.Overlay0.Brush" Color="{StaticResource Mocha.Overlay0}" />
    <SolidColorBrush x:Key="Mocha.Surface2.Brush" Color="{StaticResource Mocha.Surface2}" />
    <SolidColorBrush x:Key="Mocha.Surface1.Brush" Color="{StaticResource Mocha.Surface1}" />
    <SolidColorBrush x:Key="Mocha.Surface0.Brush" Color="{StaticResource Mocha.Surface0}" />
    <SolidColorBrush x:Key="Mocha.Mauve.Brush" Color="{StaticResource Mocha.Mauve}" />
    <SolidColorBrush x:Key="Mocha.Blue.Brush" Color="{StaticResource Mocha.Blue}" />
    <SolidColorBrush x:Key="Mocha.Lavender.Brush" Color="{StaticResource Mocha.Lavender}" />
    <SolidColorBrush x:Key="Mocha.Red.Brush" Color="{StaticResource Mocha.Red}" />
    <SolidColorBrush x:Key="Mocha.Green.Brush" Color="{StaticResource Mocha.Green}" />
    <SolidColorBrush x:Key="Mocha.Yellow.Brush" Color="{StaticResource Mocha.Yellow}" />
    <SolidColorBrush x:Key="Mocha.OnAccent.Brush" Color="{StaticResource Mocha.Base}" />

    <FontFamily x:Key="Mocha.Font">Segoe UI Variable Text, Segoe UI</FontFamily>

    <!-- Standard text style -->
    <Style x:Key="Mocha.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <Style x:Key="Mocha.Body.Subtle" TargetType="TextBlock" BasedOn="{StaticResource Mocha.Body}">
        <Setter Property="Foreground" Value="{StaticResource Mocha.Subtext0.Brush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="Mocha.Body.Header" TargetType="TextBlock" BasedOn="{StaticResource Mocha.Body}">
        <Setter Property="Foreground" Value="{StaticResource Mocha.Mauve.Brush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Mocha.Body.Title" TargetType="TextBlock" BasedOn="{StaticResource Mocha.Body}">
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <Style x:Key="Mocha.Body.Section" TargetType="TextBlock" BasedOn="{StaticResource Mocha.Body}">
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Mocha.Body.Caption" TargetType="TextBlock" BasedOn="{StaticResource Mocha.Body.Subtle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Setter Property="LineHeight" Value="17" />
    </Style>

    <Style x:Key="Mocha.Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Surface1.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,12" />
    </Style>

    <Style x:Key="Mocha.Badge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Mocha.Surface0.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Surface1.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinHeight" Value="22" />
    </Style>

    <!-- Snippet row button: rectangular hover with 6px radius -->
    <Style x:Key="Mocha.SnippetRow" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="4,1"
                            BorderThickness="1"
                            BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface0.Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface1.Brush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Standard button -->
    <Style x:Key="Mocha.Button" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Background" Value="{StaticResource Mocha.Surface0.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface1.Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface2.Brush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Surface1.Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Mocha.Button.Accent" TargetType="Button" BasedOn="{StaticResource Mocha.Button}">
        <Setter Property="Background" Value="{StaticResource Mocha.Mauve.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.OnAccent.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="Mocha.Button.Danger" TargetType="Button" BasedOn="{StaticResource Mocha.Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Red.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Red.Brush}" />
    </Style>

    <!-- TextBox -->
    <Style x:Key="Mocha.TextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Mocha.Surface2.Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.58" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Mocha.PasswordBox" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Mocha.Surface2.Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.58" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox -->
    <Style x:Key="Mocha.ListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer Padding="4">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Mocha.ListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface0.Brush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface1.Brush}" />
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{StaticResource Mocha.Mauve.Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox -->
    <Style x:Key="Mocha.CheckBox" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="30" />
    </Style>

    <!-- Separator -->
    <Style x:Key="Mocha.Separator" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource Mocha.Surface1.Brush}" />
        <Setter Property="Margin" Value="6,4" />
    </Style>

    <!-- ContextMenu (used for the tray-icon right-click menu) -->
    <Style x:Key="Mocha.ContextMenu" TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel IsItemsHost="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Mocha.MenuItem" TargetType="MenuItem">
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bg"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Margin="0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Header"
                                              VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource Mocha.Subtext0.Brush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Mocha.Surface0.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox — minimal Latte skin -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Mocha.Overlay0.Brush}" />
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource Mocha.Mantle.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource Mocha.Text.Brush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontFamily" Value="{StaticResource Mocha.Font}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="Mocha.MenuSeparator" TargetType="Separator">
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Background" Value="{StaticResource Mocha.Surface1.Brush}" />
        <Setter Property="Height" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Background="{TemplateBinding Background}" Height="1" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
