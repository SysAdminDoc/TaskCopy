<Window x:Class="TaskCopy.Views.TrashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        Title="TaskCopy — Trash"
        Width="560" Height="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:TrashViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Trashed snippets — auto-purged 30 days after deletion."
                   Style="{StaticResource Mocha.Body.Subtle}"
                   TextWrapping="Wrap"
                   Margin="2,0,0,8" />

        <ListBox Grid.Row="1"
                 Style="{StaticResource Mocha.ListBox}"
                 ItemContainerStyle="{StaticResource Mocha.ListBoxItem}"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding Selected}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:TrashedRow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding Title}" Style="{StaticResource Mocha.Body}" />
                            <TextBlock Text="{Binding Preview}" Style="{StaticResource Mocha.Body.Subtle}" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding DeletedAtLabel}" Style="{StaticResource Mocha.Body.Subtle}" />
                            <TextBlock Text="{Binding PurgesInLabel}" Style="{StaticResource Mocha.Body.Subtle}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Style="{StaticResource Mocha.Button.Accent}"
                    Content="Restore"
                    Command="{Binding RestoreCommand}" />
            <Button Style="{StaticResource Mocha.Button.Danger}"
                    Content="Delete permanently"
                    Command="{Binding DeletePermanentlyCommand}"
                    Margin="8,0,0,0" />
            <Button Style="{StaticResource Mocha.Button.Danger}"
                    Content="Empty Trash"
                    Command="{Binding EmptyTrashCommand}"
                    Margin="8,0,0,0" />
        </StackPanel>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource Mocha.Button}"
                    Content="Close"
                    Width="80"
                    IsCancel="True"
                    Click="OnClose" />
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource Mocha.Body.Subtle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</Window>
