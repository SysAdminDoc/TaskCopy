<Window x:Class="TaskCopy.Views.BodyHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        xmlns:models="clr-namespace:TaskCopy.Models"
        Title="TaskCopy — Edit history"
        Width="640" Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:BodyHistoryViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   Style="{StaticResource Mocha.Body.Title}"
                   Margin="2,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Restore a previous body version or remove history you no longer need. TaskCopy keeps the 10 most recent saves per snippet."
                   Style="{StaticResource Mocha.Body.Caption}"
                   Margin="2,0,0,12" />

        <Grid Grid.Row="2">
            <ListBox Style="{StaticResource Mocha.ListBox}"
                     ItemContainerStyle="{StaticResource Mocha.ListBoxItem}"
                     ItemsSource="{Binding Entries}"
                     SelectedItem="{Binding Selected}"
                     Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BodyHistoryEntry}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Preview}"
                                           Style="{StaticResource Mocha.Body}"
                                           ToolTip="{Binding Body}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SavedAtDisplay}"
                                       Style="{StaticResource Mocha.Body.Subtle}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,2,0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Style="{StaticResource Mocha.Panel}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    MaxWidth="360"
                    Visibility="{Binding HasEntries, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="No versions yet"
                               Style="{StaticResource Mocha.Body.Section}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="History appears after you edit and save this snippet body."
                               Style="{StaticResource Mocha.Body.Caption}"
                               TextAlignment="Center"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Button Style="{StaticResource Mocha.Button.Accent}"
                    Content="Restore"
                    Command="{Binding RestoreCommand}" />
            <Button Style="{StaticResource Mocha.Button.Danger}"
                    Content="Delete this version"
                    Command="{Binding DeleteEntryCommand}"
                    Margin="8,0,0,0" />
        </StackPanel>

        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource Mocha.Button}"
                    Content="Close"
                    Width="80"
                    IsCancel="True"
                    Click="OnClose" />
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource Mocha.Body.Subtle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</Window>
