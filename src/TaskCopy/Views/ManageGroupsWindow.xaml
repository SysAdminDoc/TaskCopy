<Window x:Class="TaskCopy.Views.ManageGroupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        xmlns:models="clr-namespace:TaskCopy.Models"
        Title="TaskCopy — Manage groups"
        Width="460" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:ManageGroupsViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Groups" Style="{StaticResource Mocha.Body.Header}" Margin="2,0,0,6" />

        <ListBox Grid.Row="1"
                 x:Name="GroupList"
                 Style="{StaticResource Mocha.ListBox}"
                 ItemContainerStyle="{StaticResource Mocha.ListBoxItem}"
                 ItemsSource="{Binding Groups}"
                 SelectedItem="{Binding SelectedGroup}"
                 MouseDoubleClick="OnGroupDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SnippetGroup}">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource Mocha.Body}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Style="{StaticResource Mocha.Button}" Content="Rename…" Click="OnRenameClicked" IsEnabled="{Binding HasSelection}" />
            <Button Style="{StaticResource Mocha.Button.Danger}" Content="Delete" Command="{Binding DeleteGroupCommand}" Margin="8,0,0,0" />
            <Button Style="{StaticResource Mocha.Button}" Content="↑" Command="{Binding MoveGroupUpCommand}" Margin="8,0,0,0" Width="34" />
            <Button Style="{StaticResource Mocha.Button}" Content="↓" Command="{Binding MoveGroupDownCommand}" Margin="4,0,0,0" Width="34" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBox Style="{StaticResource Mocha.TextBox}"
                     Width="240"
                     Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}" />
            <Button Style="{StaticResource Mocha.Button.Accent}"
                    Content="Add"
                    Command="{Binding AddGroupCommand}"
                    Margin="8,0,0,0" />
        </StackPanel>

        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource Mocha.Button}"
                    Content="Close"
                    Width="80"
                    IsCancel="True"
                    Click="OnClose" />
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource Mocha.Body.Subtle}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</Window>
