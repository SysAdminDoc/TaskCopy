<Window x:Class="TaskCopy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        xmlns:models="clr-namespace:TaskCopy.Models"
        mc:Ignorable="d"
        Title="TaskCopy — Settings"
        Width="820" Height="540"
        MinWidth="640" MinHeight="420"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left: snippet list -->
        <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Snippets"
                       Style="{StaticResource Mocha.Body.Header}"
                       Margin="2,0,0,6" />

            <ListBox Grid.Row="1"
                     x:Name="SnippetList"
                     Style="{StaticResource Mocha.ListBox}"
                     ItemContainerStyle="{StaticResource Mocha.ListBoxItem}"
                     ItemsSource="{Binding Snippets}"
                     SelectedItem="{Binding SelectedSnippet}"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="OnSnippetListMouseDown"
                     PreviewMouseMove="OnSnippetListMouseMove"
                     DragOver="OnSnippetListDragOver"
                     Drop="OnSnippetListDrop"
                     PreviewKeyDown="OnSnippetListKeyDown"
                     AutomationProperties.Name="Snippets"
                     AutomationProperties.HelpText="List of saved snippets. Drag to reorder. Del to delete, Ctrl+N to add, F2 to rename. Use Add / Delete / Move buttons or arrow keys.">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Snippet}">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource Mocha.Body}"
                                       ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Style="{StaticResource Mocha.Body.Subtle}"
                                       Margin="0,2,0,0"
                                       ToolTip="{Binding Body}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Style="{StaticResource Mocha.Button.Accent}" Content="Add" Command="{Binding AddSnippetCommand}" />
                <Button Style="{StaticResource Mocha.Button.Danger}" Content="Delete" Command="{Binding DeleteSnippetCommand}" Margin="8,0,0,0" />
                <Button Style="{StaticResource Mocha.Button}" Content="↑" Command="{Binding MoveUpCommand}" Margin="8,0,0,0" Width="34" />
                <Button Style="{StaticResource Mocha.Button}" Content="↓" Command="{Binding MoveDownCommand}" Margin="4,0,0,0" Width="34" />
            </StackPanel>
        </Grid>

        <!-- Right: editor + preferences -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Title" Style="{StaticResource Mocha.Body.Header}" Margin="2,0,0,4" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,4">
                    <TextBlock Text="Group:" Style="{StaticResource Mocha.Body.Subtle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="180"
                              ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding EditGroup}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding HasSelection}"
                              ToolTip="Move this snippet to a group, or pick (Ungrouped)." />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Manage…"
                            Command="{Binding ManageGroupsCommand}"
                            Margin="6,0,0,0"
                            ToolTip="Add / rename / delete / reorder groups." />
                </StackPanel>
            </Grid>
            <TextBox Grid.Row="1"
                     Style="{StaticResource Mocha.TextBox}"
                     Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding HasSelection}"
                     AutomationProperties.Name="Snippet title" />

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Body" Style="{StaticResource Mocha.Body.Header}" Margin="2,0,0,4" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,4">
                        <CheckBox Style="{StaticResource Mocha.CheckBox}"
                                  Content="📌 Pin"
                                  IsChecked="{Binding EditPinned}"
                                  IsEnabled="{Binding HasSelection}"
                                  ToolTip="Promote this snippet to the top of the flyout (in 'Most used' or 'Recently used' modes)." />
                        <CheckBox Style="{StaticResource Mocha.CheckBox}"
                                  Content="Monospace"
                                  IsChecked="{Binding EditIsMonospace}"
                                  IsEnabled="{Binding HasSelection}"
                                  ToolTip="Switch this snippet's editor and tooltip to a monospaced font (good for code)."
                                  Margin="14,0,0,0" />
                        <TextBlock Text="Hotkey:" Style="{StaticResource Mocha.Body.Subtle}" VerticalAlignment="Center" Margin="14,0,6,0" />
                        <TextBlock Text="{Binding EditQuickHotkeyDisplay}"
                                   Style="{StaticResource Mocha.Body}"
                                   VerticalAlignment="Center"
                                   MinWidth="100"
                                   Margin="0,0,6,0" />
                        <Button Style="{StaticResource Mocha.Button}"
                                Content="Capture…"
                                Command="{Binding RebindQuickHotkeyCommand}"
                                ToolTip="Bind any global combo (e.g. Ctrl+Alt+S) so this snippet copies (+ auto-pastes) from anywhere without opening the flyout." />
                        <Button Style="{StaticResource Mocha.Button}"
                                Content="Clear"
                                Command="{Binding ClearQuickHotkeyBindingCommand}"
                                Margin="4,0,0,0"
                                ToolTip="Remove the per-snippet hotkey binding." />
                    </StackPanel>
                </Grid>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Paste:" Style="{StaticResource Mocha.Body.Subtle}" VerticalAlignment="Center" Margin="2,0,6,0" />
                    <ComboBox Width="160"
                              ItemsSource="{Binding PasteModeOptions}"
                              SelectedItem="{Binding EditPasteMode}"
                              DisplayMemberPath="Label"
                              IsEnabled="{Binding HasSelection}"
                              ToolTip="Auto (default) sends Ctrl+V. Type characters synthesises each character via Unicode SendInput — use it for terminals and other apps that swallow Ctrl+V."
                              Margin="0,0,14,0" />
                    <TextBlock Text="Insert:" Style="{StaticResource Mocha.Body.Subtle}" VerticalAlignment="Center" Margin="2,0,8,0" />
                    <Button Style="{StaticResource Mocha.Button}" Content="{}{{date}}" Click="OnInsertDate"
                            ToolTip="Inserts {{date}} — replaced by today's ISO date at paste time." />
                    <Button Style="{StaticResource Mocha.Button}" Content="{}{{time}}" Click="OnInsertTime" Margin="4,0,0,0"
                            ToolTip="Inserts {{time}} — replaced by current local time at paste time." />
                    <Button Style="{StaticResource Mocha.Button}" Content="{}{{clipboard}}" Click="OnInsertClipboard" Margin="4,0,0,0"
                            ToolTip="Inserts {{clipboard}} — replaced by the contents of the clipboard before TaskCopy opened." />
                    <Button Style="{StaticResource Mocha.Button}" Content="{}{{cursor}}" Click="OnInsertCursor" Margin="4,0,0,0"
                            ToolTip="Inserts {{cursor}} — after auto-paste, places the caret here." />
                    <Button Style="{StaticResource Mocha.Button}" Content="{}{{ask:…}}" Click="OnInsertAsk" Margin="4,0,0,0"
                            ToolTip="Inserts {{ask:Field}} — prompts for a value at paste time." />
                </StackPanel>
                <TextBox Grid.Row="2"
                         x:Name="BodyEditor"
                         Style="{StaticResource Mocha.TextBox}"
                         Text="{Binding EditBody, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding HasSelection}"
                         FontFamily="{Binding EditBodyFontFamily}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         AutomationProperties.Name="Snippet body"
                         AutomationProperties.HelpText="Use the Insert buttons above to add placeholders like {{date}} or {{cursor}}." />
                <Border Grid.Row="3"
                        Background="{StaticResource Mocha.Mantle.Brush}"
                        BorderBrush="{StaticResource Mocha.Overlay0.Brush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6"
                        Margin="0,6,0,0"
                        MaxHeight="80"
                        ToolTip="Live preview — placeholders are resolved against today's date, a sample clipboard, and stub Ask/Form responses.">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding EditBodyPreview}"
                                   FontFamily="{Binding EditBodyFontFamily}"
                                   Foreground="{StaticResource Mocha.Subtext0.Brush}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource Mocha.Separator}" Margin="0,12,0,8" />

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Global hotkey"
                           Style="{StaticResource Mocha.Body.Header}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding HotkeyStatusBrush}"
                             Margin="0,0,6,0"
                             ToolTip="{Binding HotkeyStatusLabel}" />
                    <TextBlock Text="{Binding HotkeyDisplay}"
                               Style="{StaticResource Mocha.Body}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Rebind…"
                            Command="{Binding RebindHotkeyCommand}" />
                </StackPanel>

                <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                          Style="{StaticResource Mocha.CheckBox}"
                          Content="Start TaskCopy with Windows"
                          IsChecked="{Binding StartWithWindows}"
                          Margin="0,10,0,0" />

                <CheckBox Grid.Row="2" Grid.ColumnSpan="2"
                          Style="{StaticResource Mocha.CheckBox}"
                          Content="Auto-paste into the previous window after copy"
                          IsChecked="{Binding AutoPaste}"
                          ToolTip="When ON, TaskCopy refocuses the window that was active before you opened the flyout and sends Ctrl+V automatically."
                          Margin="0,6,0,0" />

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <CheckBox Style="{StaticResource Mocha.CheckBox}"
                              Content="Capture recent clipboard items"
                              IsChecked="{Binding RecentClipsEnabled}"
                              ToolTip="When ON, TaskCopy keeps the last ~50 plain-text clipboard items. Respects the standard 'do not include in clipboard history' flag set by password managers." />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Clear"
                            Command="{Binding ClearRecentClipsCommand}"
                            Margin="12,0,0,0"
                            ToolTip="Delete every stored recent clipboard item from the database." />
                </StackPanel>

                <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Flyout order"
                               Style="{StaticResource Mocha.Body.Header}"
                               VerticalAlignment="Center" />
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Width="240"
                              ItemsSource="{Binding FlyoutSortModes}"
                              SelectedItem="{Binding SelectedFlyoutSort}"
                              DisplayMemberPath="Label"
                              ToolTip="How the snippet flyout sorts items. Manual respects your drag order exactly; other modes always promote pinned snippets to the top." />
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Theme"
                               Style="{StaticResource Mocha.Body.Header}"
                               VerticalAlignment="Center"
                               Margin="0,8,0,0" />
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              Width="240"
                              ItemsSource="{Binding ThemeOptions}"
                              SelectedItem="{Binding SelectedTheme}"
                              DisplayMemberPath="Label"
                              Margin="0,8,0,0"
                              ToolTip="Catppuccin Mocha (default), Catppuccin Latte (light), or Follow system (reads HKCU AppsUseLightTheme at launch). Picking a new theme prompts to relaunch — Settings reopens automatically." />
                </Grid>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,12,0,0">
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Export snippets…"
                            Command="{Binding ExportSnippetsCommand}"
                            ToolTip="Save all snippets and groups as a JSON file." />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Import snippets…"
                            Command="{Binding ImportSnippetsCommand}"
                            ToolTip="Load snippets from a JSON file. Duplicates (by title) are skipped."
                            Margin="8,0,0,0" />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Trash…"
                            Command="{Binding ShowTrashCommand}"
                            Margin="8,0,0,0"
                            ToolTip="Restore recently deleted snippets. Auto-purged after 30 days." />
                    <Border Width="1" Background="{StaticResource Mocha.Surface1.Brush}" Margin="12,4" />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Restore backup…"
                            Command="{Binding RestoreBackupCommand}"
                            ToolTip="Pick a rotated backup (.bak.0/1/2) and swap it in for the current snippets.db. A pre-restore snapshot is taken so the operation is itself reversible." />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Copy diagnostics"
                            Command="{Binding CopyDiagnosticsCommand}"
                            Margin="8,0,0,0"
                            ToolTip="Bundles version, schema version, snippet count, last-backup timestamp, and the tail of crash.log into a Markdown block on the clipboard — paste it into a GitHub issue." />
                    <Border Width="1" Background="{StaticResource Mocha.Surface1.Brush}" Margin="12,4" />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Open log folder"
                            Command="{Binding OpenLogFolderCommand}"
                            ToolTip="Opens %LOCALAPPDATA%\TaskCopy\logs — useful when filing a bug." />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Open data folder"
                            Command="{Binding OpenDataFolderCommand}"
                            ToolTip="Opens %LOCALAPPDATA%\TaskCopy — contains snippets.db and backups."
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Mocha.Separator}" Margin="0,12,0,6" />
        <Grid Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Bottom" Margin="2,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       Style="{StaticResource Mocha.Body.Subtle}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1"
                       Text="{Binding SnippetCountStatus}"
                       Style="{StaticResource Mocha.Body.Subtle}"
                       Margin="12,0,2,0" />
        </Grid>
    </Grid>
</Window>
