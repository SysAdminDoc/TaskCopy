<Window x:Class="TaskCopy.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        xmlns:models="clr-namespace:TaskCopy.Models"
        mc:Ignorable="d"
        Title="TaskCopy — Settings"
        Width="820" Height="540"
        MinWidth="640" MinHeight="420"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:SettingsViewModel}">

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Left: snippet list -->
        <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Snippets"
                       Style="{StaticResource Mocha.Body.Header}"
                       Margin="2,0,0,6" />

            <ListBox Grid.Row="1"
                     Style="{StaticResource Mocha.ListBox}"
                     ItemContainerStyle="{StaticResource Mocha.ListBoxItem}"
                     ItemsSource="{Binding Snippets}"
                     SelectedItem="{Binding SelectedSnippet}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Snippet}">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource Mocha.Body}"
                                       ToolTip="{Binding Title}" />
                            <TextBlock Text="{Binding Preview}"
                                       Style="{StaticResource Mocha.Body.Subtle}"
                                       Margin="0,2,0,0"
                                       ToolTip="{Binding Body}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Style="{StaticResource Mocha.Button.Accent}" Content="Add" Command="{Binding AddSnippetCommand}" />
                <Button Style="{StaticResource Mocha.Button.Danger}" Content="Delete" Command="{Binding DeleteSnippetCommand}" Margin="8,0,0,0" />
                <Button Style="{StaticResource Mocha.Button}" Content="↑" Command="{Binding MoveUpCommand}" Margin="8,0,0,0" Width="34" />
                <Button Style="{StaticResource Mocha.Button}" Content="↓" Command="{Binding MoveDownCommand}" Margin="4,0,0,0" Width="34" />
            </StackPanel>
        </Grid>

        <!-- Right: editor + preferences -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Title" Style="{StaticResource Mocha.Body.Header}" Margin="2,0,0,4" />
            <TextBox Grid.Row="1"
                     Style="{StaticResource Mocha.TextBox}"
                     Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding HasSelection}" />

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Body" Style="{StaticResource Mocha.Body.Header}" Margin="2,0,0,4" />
                <TextBox Grid.Row="1"
                         Style="{StaticResource Mocha.TextBox}"
                         Text="{Binding EditBody, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding HasSelection}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" />
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource Mocha.Separator}" Margin="0,12,0,8" />

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Global hotkey"
                           Style="{StaticResource Mocha.Body.Header}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding HotkeyDisplay}"
                               Style="{StaticResource Mocha.Body}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Button Style="{StaticResource Mocha.Button}"
                            Content="Rebind…"
                            Command="{Binding RebindHotkeyCommand}" />
                </StackPanel>

                <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                          Style="{StaticResource Mocha.CheckBox}"
                          Content="Start TaskCopy with Windows"
                          IsChecked="{Binding StartWithWindows}"
                          Margin="0,10,0,0" />

                <CheckBox Grid.Row="2" Grid.ColumnSpan="2"
                          Style="{StaticResource Mocha.CheckBox}"
                          Content="Auto-paste into the previous window after copy (v0.2 preview)"
                          IsChecked="{Binding AutoPaste}"
                          IsEnabled="False"
                          Margin="0,6,0,0" />
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource Mocha.Separator}" Margin="0,12,0,6" />
        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                   Text="{Binding StatusMessage}"
                   Style="{StaticResource Mocha.Body.Subtle}"
                   VerticalAlignment="Bottom"
                   Margin="2,0,0,0" />
    </Grid>
</Window>
