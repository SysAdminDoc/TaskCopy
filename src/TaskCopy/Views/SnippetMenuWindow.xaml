<Window x:Class="TaskCopy.Views.SnippetMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TaskCopy.ViewModels"
        xmlns:models="clr-namespace:TaskCopy.Models"
        mc:Ignorable="d"
        Title="TaskCopy"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        ShowActivated="True"
        UseLayoutRounding="True"
        d:DataContext="{d:DesignInstance vm:SnippetMenuViewModel}">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Mocha.Base.Brush}"
            BorderBrush="{StaticResource Mocha.Overlay0.Brush}"
            BorderThickness="1"
            CornerRadius="10"
            Margin="12"
            MinWidth="320"
            MaxWidth="420">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="2"
                              Direction="270"
                              Color="Black"
                              Opacity="0.55" />
        </Border.Effect>

        <Grid Margin="0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" MaxHeight="420" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="{Binding StatusText}"
                       Style="{StaticResource Mocha.Body.Header}"
                       Margin="16,4,16,8" />

            <!-- Separator -->
            <Border Grid.Row="1" Style="{StaticResource Mocha.Separator}" />

            <!-- Snippet list -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding HasSnippets, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Snippets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Snippet}">
                            <Button Style="{StaticResource Mocha.SnippetRow}"
                                    Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource Mocha.Body}" />
                                    <TextBlock Text="{Binding Preview}"
                                               Style="{StaticResource Mocha.Body.Subtle}"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <Border Grid.Row="2"
                    Padding="20,16"
                    Visibility="{Binding HasSnippets, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="No snippets yet"
                               Style="{StaticResource Mocha.Body}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Open Edit snippets to add your first one."
                               Style="{StaticResource Mocha.Body.Subtle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border Grid.Row="3" Style="{StaticResource Mocha.Separator}" />

            <!-- Edit snippets -->
            <Button Grid.Row="4"
                    Style="{StaticResource Mocha.SnippetRow}"
                    Command="{Binding EditCommand}">
                <TextBlock Text="Edit snippets…" Style="{StaticResource Mocha.Body}" />
            </Button>

            <!-- Quit -->
            <Button Grid.Row="5"
                    Style="{StaticResource Mocha.SnippetRow}"
                    Command="{Binding QuitCommand}">
                <TextBlock Text="Quit TaskCopy" Style="{StaticResource Mocha.Body}" />
            </Button>
        </Grid>
    </Border>
</Window>
