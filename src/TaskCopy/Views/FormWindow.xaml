<Window x:Class="TaskCopy.Views.FormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskCopy"
        Width="440"
        SizeToContent="Height"
        MinHeight="180"
        MaxHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Mocha.Base.Brush}"
        Foreground="{StaticResource Mocha.Text.Brush}"
        FontFamily="{StaticResource Mocha.Font}"
        FontSize="13"
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Snippet fields"
                   Style="{StaticResource Mocha.Body.Header}"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1"
                      MaxHeight="360"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="FieldsPanel" />
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Style="{StaticResource Mocha.Button}"
                    Content="Cancel"
                    Width="80"
                    IsCancel="True"
                    Click="OnCancel" />
            <Button Style="{StaticResource Mocha.Button.Accent}"
                    Content="OK"
                    Width="80"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Click="OnOk" />
        </StackPanel>
    </Grid>
</Window>
